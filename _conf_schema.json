{
  "wegame_api_key": {
    "type": "string",
    "description": "WeGame API Key",
    "hint": "用于访问 WeGame API 的开发者密钥",
    "default": ""
  },
  "api_base_url": {
    "type": "string",
    "description": "API 基础地址",
    "hint": "WeGame API 服务器地址",
    "default": "https://wegame.shallow.ink"
  },
  "render_timeout": {
    "type": "int",
    "description": "渲染超时时间",
    "hint": "图片渲染最大等待时间（毫秒）",
    "default": 30000
  },
  "auto_refresh_enabled": {
    "type": "bool",
    "description": "启用自动刷新",
    "hint": "定时刷新所有用户凭证，非必要不要开启！服务端会自动刷新",
    "default": false
  },
  "auto_refresh_time": {
    "type": "list",
    "description": "自动刷新时间",
    "hint": "每天自动刷新的时间点（24 小时制）",
    "default": ["00:00", "12:00"],
    "items": {
      "type": "string"
    }
  },
  "auto_refresh_notify_group": {
    "type": "string",
    "description": "刷新结果通知 UMO",
    "hint": "自动刷新结果推送到此会话（填写完整的 UMO，如 default:GroupMessage:870543663）",
    "default": ""
  }
}